views:
  - type: list
    name: Created today
    filters:
      and:
        - date_created.format("YYYY-MM-DD") == this.file.basename
    order:
      - file.name
  - type: list
    name: Modified today
    filters:
      and:
        - date_modified.format("YYYY-MM-DD") == this.file.basename
    order:
      - file.name
